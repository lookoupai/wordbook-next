{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"slug": "canvas",
					"name": "Canvas",
					"color": "#F7F2E7"
				},
				{
					"slug": "contrast",
					"name": "Contrast",
					"color": "#1F2430"
				},
				{
					"slug": "sidebar",
					"name": "Sidebar",
					"color": "#0F1520"
				},
				{
					"slug": "accent",
					"name": "Accent",
					"color": "#CB8332"
				},
				{
					"slug": "line",
					"name": "Line",
					"color": "#D8D1C4"
				},
				{
					"slug": "link",
					"name": "Link",
					"color": "#235FA8"
				},
				{
					"slug": "paper",
					"name": "Paper",
					"color": "#FFFDF8"
				}
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1100px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"slug": "30",
					"name": "XS",
					"size": "0.75rem"
				},
				{
					"slug": "40",
					"name": "S",
					"size": "1rem"
				},
				{
					"slug": "50",
					"name": "M",
					"size": "1.5rem"
				},
				{
					"slug": "60",
					"name": "L",
					"size": "clamp(1.75rem, 3vw, 2.5rem)"
				},
				{
					"slug": "70",
					"name": "XL",
					"size": "clamp(2.5rem, 5vw, 4rem)"
				}
			],
			"units": [
				"px",
				"rem",
				"em",
				"%",
				"vw",
				"vh"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "Sans",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", \"PingFang SC\", \"Noto Sans SC\", sans-serif"
				},
				{
					"slug": "serif",
					"name": "Serif",
					"fontFamily": "\"Noto Serif SC\", \"Source Han Serif SC\", Georgia, serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "\"SFMono-Regular\", Consolas, \"Liberation Mono\", monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.95rem"
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1.05rem"
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.35rem"
				},
				{
					"slug": "x-large",
					"name": "XL",
					"size": "clamp(1.9rem, 3vw, 2.35rem)"
				},
				{
					"slug": "xx-large",
					"name": "XXL",
					"size": "clamp(2.4rem, 4vw, 3.25rem)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|canvas",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"blockGap": "1.35rem"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|sans",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.75"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var:preset|color|link"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|sans",
					"fontWeight": "650",
					"lineHeight": "1.2"
				}
			}
		},
		"blocks": {
			"core/code": {
				"color": {
					"background": "#EFE7D6",
					"text": "#233041"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|mono",
					"fontSize": "0.92em"
				},
				"spacing": {
					"padding": {
						"top": "0.2rem",
						"right": "0.4rem",
						"bottom": "0.2rem",
						"left": "0.4rem"
					}
				}
			},
			"core/preformatted": {
				"color": {
					"background": "#EFE7D6",
					"text": "#233041"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|mono"
				},
				"spacing": {
					"padding": {
						"top": "1rem",
						"right": "1rem",
						"bottom": "1rem",
						"left": "1rem"
					}
				}
			},
			"core/quote": {
				"border": {
					"width": "0 0 0 4px"
				},
				"color": {
					"text": "#664B24"
				},
				"spacing": {
					"padding": {
						"left": "1.25rem"
					}
				}
			},
			"core/table": {
				"border": {
					"color": "#D8D1C4"
				}
			},
			"core/list": {
				"spacing": {
					"blockGap": "0.45rem"
				}
			},
			"core/image": {
				"spacing": {
					"margin": {
						"top": "var:preset|spacing|50",
						"bottom": "var:preset|spacing|50"
					}
				}
			}
		}
	}
}
